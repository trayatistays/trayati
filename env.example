NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Clerk auth, used only when a traveler clicks Reserve Now.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Admin panel login.
TRAYATI_ADMIN_USERNAME=change-me
TRAYATI_ADMIN_PASSWORD=change-me

# Supabase database and storage.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=trayati-media

# Upstash Redis for availability cache and booking locks.
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Razorpay checkout and webhook verification.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Vercel cron protection for /api/cron/ical-sync.
CRON_SECRET=change-me

# Resend for booking confirmation emails.
RESEND_API_KEY=re_xxx
ADMIN_EMAIL=your-email@example.com

# Instagram feed for the moving footer carousel.
INSTAGRAM_ACCESS_TOKEN=your-instagram-long-lived-token
